# 个人量化系统 - 环境变量配置示例
# 复制此文件为 .env 并填入真实配置值

# ============================================
# 数据源配置
# ============================================

# Tushare Token（必需）
# 获取地址: https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here

# ============================================
# GitHub Pages 部署配置（可选）
# ============================================

# GitHub Personal Access Token
# 获取地址: https://github.com/settings/tokens
# 权限要求: repo (完整仓库访问)
GITHUB_TOKEN=your_github_personal_access_token

# GitHub 仓库名称
# 格式: username/repository-name
# 示例: myusername/quant-daily-report
GITHUB_REPO=your_username/your_repository_name

# ============================================
# 告警邮箱配置（可选）
# ============================================

# 接收告警的邮箱地址
ALERT_EMAIL=your_alert_email@example.com

# SMTP 服务器配置
# Gmail: smtp.gmail.com, 端口 587
# QQ邮箱: smtp.qq.com, 端口 587
# 163邮箱: smtp.163.com, 端口 465
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_email_username
SMTP_PASSWORD=your_email_password_or_auth_code

# ============================================
# 监控配置（可选）
# ============================================

# Sentry DSN（错误监控）
# 获取地址: https://sentry.io/
SENTRY_DSN=your_sentry_dsn_here

# ============================================
# Wind 数据接口（可选，非必需）
# ============================================

# Wind 金融终端账号
WIND_USERNAME=your_wind_username
WIND_PASSWORD=your_wind_password
